# Production: set all vars in Vercel (Backend) → Settings → Environment Variables.
# CORS uses FRONTEND_URL; set to your frontend origin (e.g. https://your-app.vercel.app).

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=studybuddy
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Clerk (get JWKS URL from Clerk dashboard → API Keys → Advanced)
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Supabase (use service role key for server-side, NOT the anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:3000

# Opik LLMOps
OPIK_API_KEY=
OPIK_WORKSPACE=default
OPIK_PROJECT_NAME=studybuddy-rag
